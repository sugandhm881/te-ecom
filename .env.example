# ─── Ecom Central — environment template ─────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit `.env` (it is git-ignored).
# Every variable here is read through config.js — see PROJECT_DOCUMENTATION.md §12.

# ── Server ──
PORT=5002
JWT_SECRET=                       # REQUIRED — random string, ≥32 chars (app refuses weak secrets)
DASHBOARD_URL=http://localhost:5002

# ── Bootstrap admin (always able to log in) ──
APP_USER_EMAIL=admin@example.com
APP_USER_PASSWORD=

# ── Supabase (service role — server-side only) ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=

# ── Shopify ──
SHOPIFY_TOKEN=
SHOPIFY_SHOP_URL=<shop>.myshopify.com

# ── RapidShyp ──
RAPIDSHYP_API_URL=https://api.rapidshyp.com/rapidshyp/apis/v1/
RAPIDSHYP_API_KEY=

# ── DocPharma ──
DOCPHARMA_API_KEY=
DP_PORTAL_EMAIL=
DP_PORTAL_PASSWORD=
DP_PORTAL_TOKEN=
# DP_TRIGGER_WORD=rejected        # LIVE uses "rejected"; set "test" on local instances

# ── EasyEcom OMS ──
EASYECOM_BASE_URL=https://api.easyecom.io
EASYECOM_API_KEY=
EASYECOM_WH_KEY=
EASYECOM_JWT=
EASYECOM_EMAIL=
EASYECOM_PASSWORD=
EASYECOM_WEBHOOK_TOKEN=

# ── Amazon SP-API ──
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=eu-west-1
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=
REFRESH_TOKEN=
MARKETPLACE_ID=A21TJRUUN4KGV
BASE_URL=https://sellingpartnerapi-eu.amazon.com

# ── Meta (Facebook) Ads ──
FACEBOOK_AD_ACCOUNT_ID=
FACEBOOK_ACCESS_TOKEN=

# ── Email (SMTP defaults — the portal Settings can override these) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=                   # Gmail: 16-char App Password
RECIPIENT_EMAIL=
# EMAIL_ENC_KEY=                  # optional 64-hex-char AES key for the portal-stored SMTP password;
                                  # falls back to a key derived from JWT_SECRET — set BEFORE first use,
                                  # never change afterwards or stored passwords won't decrypt

# ── AI (critical-email polish; optional — falls back to a plain template) ──
AI_API_KEY=
AI_API_URL=https://generativelanguage.googleapis.com     # Gemini native, or an OpenAI-compatible URL
AI_MODEL=gemini-flash-latest

# ── Microsoft Teams — outbound report webhooks (Power Automate Workflows) ──
TEAMS_WEBHOOK_WAREHOUSE=
TEAMS_WEBHOOK_DP=
TEAMS_WEBHOOK_HOLD=
TEAMS_WEBHOOK_AMAZON=

# ── Microsoft Teams — inbound keyword listener (Graph delegated) ──
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_REFRESH_TOKEN=              # auto-rotates; run the listener in ONE process only
TEAMS_TEAM_ID=
TEAMS_CHANNEL_DP=
TEAMS_CHANNEL_AMAZON=
# TEAMS_LISTENER_DRYRUN=1         # log-only mode for the listener

# ── Slack (LEGACY — decommissioned; posting stays off unless explicitly enabled) ──
# SLACK_ENABLED=true
# SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Misc ──
PICKUP_PINCODE=122101             # warehouse origin pincode (serviceability/EDD)
AUTO_REVIEW_CRON=0 10 * * *       # Amazon auto-review schedule (IST)
# CACHE_DIR=.
# GOOGLE_CREDENTIALS={...}        # Google service-account JSON (single line)
