{
  "manifest_version": 3,
  "name": "Ecom Central — EasyEcom Warehouse Router",
  "version": "1.1.2",
  "description": "Runs EasyEcom warehouse changes from your browser (your IP) so they clear EasyEcom's bot firewall, and keeps the dashboard session fresh. No passwords stored.",
  "permissions": ["cookies", "alarms", "storage"],
  "host_permissions": [
    "https://*.easyecom.io/*",
    "https://app.easyecom.io/*",
    "https://dashboard.theelement.skin/*"
  ],
  "background": { "scripts": ["background.js"] },
  "action": { "default_popup": "popup.html", "default_title": "EasyEcom Warehouse Router" },
  "browser_specific_settings": {
    "gecko": {
      "id": "ee-warehouse-router@theelement.skin",
      "strict_min_version": "128.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
